# This file ensures no secret config is accidentally baked into the image.
# Images may be pushed to public registries, so exclude env files and sensitive config.

# IDE, OS, and dev tooling
.idea
.vscode
.DS_Store
.claude

# No need to send pre-built binaries into build context
*.exe
*.exe~
cmd/main/main

# Go testing output
*.out
*.test
profile*.pdf

# Go workspace file, local dev only, can break builds if included
go.work
go.work.sum

# Config that may contain secrets (DB credentials, API keys, etc.)
config/.env
config/.env.*
config/*ignore*.sh
