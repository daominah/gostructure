# Cursor ignore patterns
# This file controls which files Cursor AI can access

# Block access to SSH directories at any path level
**/.ssh/

# Block access to config files that may contain sensitive information
# but allow .env.example so devs know which environment variables are needed
config/.env*
!config/.env.example

# Block access to sensitive dotfiles (synced with .claude/settings.json)
**/.docker*
**/.netrc*
**/.config/
**/.gnupg/
**/.gsutil/
**/.kube/
